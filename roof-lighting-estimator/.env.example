# Google Maps API Key
# Get your key from: https://developers.google.com/maps/documentation/javascript/get-api-key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Gemini API Key (if using AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — Trial Gate (Lead Capture)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# Also add these as Environment Variables in your Vercel project settings.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
